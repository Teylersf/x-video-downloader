{
  "manifest_version": 3,
  "name": "X Video Downloader",
  "version": "2.0",
  "description": "Auto-scroll and download videos from X/Twitter feed",
  "permissions": [
    "downloads",
    "storage",
    "activeTab",
    "scripting",
    "cookies",
    "webRequest"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://video.twimg.com/*",
    "https://api.x.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
